{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint resources/js --ext .js,.jsx,.ts,.tsx",
        "lint:fix": "eslint resources/js --ext .js,.jsx,.ts,.tsx --fix",
        "format": "prettier --write resources/js/**/*.{js,jsx,ts,tsx}",
        "format:check": "prettier --check resources/js/**/*.{js,jsx,ts,tsx}",
        "type-check": "tsc --noEmit",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:ci": "jest --ci --coverage --watchAll=false",
        "test:watermelondb": "jest tests/js/Database tests/js/Services/WatermelonDBService.test.js",
        "test:watermelondb:watch": "jest tests/js/Database tests/js/Services/WatermelonDBService.test.js --watch",
        "test:watermelondb:coverage": "jest tests/js/Database tests/js/Services/WatermelonDBService.test.js --coverage",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:report": "playwright show-report",
        "ci": "npm run lint && npm run format:check && npm run type-check && npm run test:ci",
        "prepare": "husky install || true"
    },
    "devDependencies": {
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/plugin-proposal-decorators": "^7.28.0",
        "@babel/plugin-transform-class-properties": "^7.27.1",
        "@babel/plugin-transform-runtime": "^7.28.0",
        "@babel/preset-env": "^7.28.0",
        "@babel/preset-react": "^7.27.1",
        "@babel/preset-typescript": "^7.27.1",
        "@eslint/js": "^9.31.0",
        "@headlessui/react": "^2.2.2",
        "@inertiajs/react": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^22.15.17",
        "@types/react": "^19.1.3",
        "@types/react-dom": "^19.1.3",
        "@types/ziggy-js": "^1.8.0",
        "@typescript-eslint/eslint-plugin": "^8.37.0",
        "@typescript-eslint/parser": "^8.37.0",
        "@vitejs/plugin-react": "^4.2.0",
        "autoprefixer": "^10.4.12",
        "axios": "^1.8.2",
        "babel-jest": "^30.0.4",
        "concurrently": "^9.0.1",
        "eslint": "^9.31.0",
        "eslint-plugin-prettier": "^5.5.3",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^16.3.0",
        "jest": "^30.0.4",
        "jest-environment-jsdom": "^30.0.4",
        "jsdom": "^26.1.0",
        "laravel-vite-plugin": "^1.2.0",
        "postcss": "^8.4.31",
        "prettier": "^3.6.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwindcss": "^3.2.1",
        "typescript": "^5.8.3",
        "vite": "^6.2.4",
        "vite-plugin-pwa": "^0.21.2",
        "workbox-window": "^7.3.0"
    },
    "dependencies": {
        "@heroicons/react": "^2.2.0",
        "@nozbe/watermelondb": "^0.28.0",
        "@nozbe/with-observables": "^1.6.0",
        "@types/react-beautiful-dnd": "^13.1.8",
        "playwright": "^1.54.1",
        "react-beautiful-dnd": "^13.1.1"
    }
}
