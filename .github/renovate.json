{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":dependencyDashboard",
    ":semanticCommits",
    ":automergeDigest",
    ":automergeBranch"
  ],
  "timezone": "Europe/London",
  "schedule": ["before 9am on Monday"],
  "labels": ["dependencies"],
  "assignees": ["wemakesit"],
  "reviewers": ["wemakesit"],
  "packageRules": [
    {
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "labels": ["composer", "automerge"]
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "labels": ["npm", "automerge"]
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "labels": ["npm", "review-required"]
    },
    {
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["composer", "major-update", "review-required"]
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["npm", "major-update", "review-required"]
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "labels": ["github-actions", "automerge"]
    },
    {
      "matchPackageNames": [
        "laravel/framework",
        "react",
        "@types/react",
        "typescript",
        "@inertiajs/react"
      ],
      "automerge": false,
      "labels": ["core-dependency", "review-required"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "vulnerability"]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on the first day of the month"]
  },
  "prConcurrentLimit": 3,
  "prHourlyLimit": 2,
  "commitMessagePrefix": "chore:",
  "commitMessageAction": "update",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{newVersion}}",
  "prTitle": "{{commitMessagePrefix}} {{commitMessageAction}} {{commitMessageTopic}} {{commitMessageExtra}}",
  "prBodyTemplate": "This PR updates {{depName}} from {{currentVersion}} to {{newVersion}}.\n\n{{#if hasReleaseNotes}}\n## Release Notes\n\n{{releaseNotes}}\n{{/if}}\n\n{{#if hasChangelog}}\n## Changelog\n\n{{changelog}}\n{{/if}}\n\n---\n\n- [ ] Tests pass\n- [ ] No breaking changes\n- [ ] Documentation updated if needed\n\nAuto-generated by Renovate Bot."
}
